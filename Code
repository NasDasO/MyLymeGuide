var suggestedPrompts = ["What does recent research say about persistent symptoms after Lyme?","How reliable is Lyme testing in the first month?","What is the difference between IDSA and ILADS treatment approaches?","What should I ask my doctor at my next visit?","Can Lyme cause long-term heart or brain problems?","What is the new Lyme vaccine?","What are red flag symptoms that need urgent attention?","How does PTLDS compare to long COVID?"];

function addChatMessage(role, html) { var area = $("chatArea"); if (!area) return null; var msg = mkEl("div", "chat-msg " + role); var avatar = mkEl("div", "chat-bubble-avatar"); avatar.textContent = role === "ai" ? "ML" : "You"; var bubble = mkEl("div", "chat-bubble", html); msg.appendChild(avatar); msg.appendChild(bubble); area.appendChild(msg); area.scrollTop = area.scrollHeight; return bubble; }
function addTypingIndicator() { var area = $("chatArea"); if (!area) return; var msg = mkEl("div", "chat-msg ai"); msg.id = "typingMsg"; var avatar = mkEl("div", "chat-bubble-avatar"); avatar.textContent = "ML"; var ind = mkEl("div", "typing-indicator"); ind.innerHTML = '<div class="typing-dot"></div><div class="typing-dot"></div><div class="typing-dot"></div>'; msg.appendChild(avatar); msg.appendChild(ind); area.appendChild(msg); area.scrollTop = area.scrollHeight; }
function removeTypingIndicator() { var m = $("typingMsg"); if (m && m.parentNode) m.parentNode.removeChild(m); }

function typeResponse(bubble, html, cb) { bubble.innerHTML = ""; var idx = 0, inTag = false, revealed = ""; function tick() { if (idx >= html.length) { bubble.innerHTML = html; var a = $("chatArea"); if (a) a.scrollTop = a.scrollHeight; if (cb) cb(); return; } var added = 0; while (added < 12 && idx < html.length) { var ch = html[idx]; if (ch === "<") inTag = true; if (inTag) { var te = html.indexOf(">", idx); if (te >= 0) { revealed += html.substring(idx, te + 1); idx = te + 1; inTag = false; } else { revealed += ch; idx++; } } else { revealed += ch; idx++; } added++; } bubble.innerHTML = revealed; var a = $("chatArea"); if (a) a.scrollTop = a.scrollHeight; setTimeout(tick, 15); } tick(); }

function getLocalContext(query) {
  if (typeof KB === "undefined" || !KB || !KB.length) return "";
  var words = query.toLowerCase().replace(/[^a-z0-9\s]/g, " ").split(/\s+/).filter(function(w) { return w.length > 1; });
  var terms = []; words.forEach(function(w) { terms.push(w); var s = w; if (s.length > 3 && s.endsWith("ing")) s = s.slice(0, -3); if (s.length > 3 && s.endsWith("ed")) s = s.slice(0, -2); if (s.length > 3 && s.endsWith("s")) s = s.slice(0, -1); terms.push(s); if (typeof SYNONYMS !== "undefined" && SYNONYMS[w]) terms.push(SYNONYMS[w]); if (typeof SYNONYMS !== "undefined" && SYNONYMS[s]) terms.push(SYNONYMS[s]); });
  var scored = KB.map(function(entry) { var score = 0; terms.forEach(function(t) { if (t.length < 2) return; entry.tags.forEach(function(tag) { if (tag === t) score += 10; else if (tag.indexOf(t) >= 0) score += 5; }); if (entry.title.toLowerCase().indexOf(t) >= 0) score += 3; if (entry.text.toLowerCase().indexOf(t) >= 0) score += 1; }); return { entry: entry, score: score }; });
  scored.sort(function(a, b) { return b.score - a.score; });
  return scored.filter(function(s) { return s.score > 2; }).slice(0, 3).map(s => `Title: ${s.entry.title}\nDetail: ${s.entry.text}`).join("\n\n");
}

async function getAIResponse(query) {
  const localContext = getLocalContext(query);
  
  if (AI_CONFIG.provider === 'openai' && AI_CONFIG.apiKey) {
    try {
      const messages = [
        { role: "system", content: AI_CONFIG.systemPrompt + (localContext ? "\n\nRelevant Context from MyLymeGuide Database:\n" + localContext : "") },
        { role: "user", content: query }
      ];
      
      const response = await fetch('https://api.openai.com/v1/chat/completions', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'Authorization': `Bearer ${AI_CONFIG.apiKey}` },
        body: JSON.stringify({ model: AI_CONFIG.model, messages: messages, temperature: 0.7, max_tokens: 500 })
      });
      
      if (!response.ok) throw new Error(`API Error: ${response.status}`);
      const data = await response.json();
      const text = data.choices[0].message.content.trim();
      const html = text.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;')
                   .replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>')
                   .replace(/\*(.*?)\*/g, '<em>$1</em>')
                   .replace(/\n/g, '<br>') + 
                   `<div class="chat-disclaimer">Powered by OpenAI. This information is for education only and does not replace professional medical advice.</div>`;
      return html;
    } catch (error) {
      console.error("OpenAI API failed, falling back to local:", error);
    }
  }
  
  if (!localContext) {
    return "<p>I can help with Lyme disease questions about symptoms, testing, treatment, prevention, and research. Try asking something specific like \"What does research say about persistent fatigue after Lyme?\" or \"How reliable is testing in the first month?\"</p><div class=\"chat-disclaimer\">This assistant provides educational information only, not medical advice.</div>";
  }
  var parts = ['<p>Based on Lyme research from 2015-2025, here is what the evidence says:</p>'];
  var entries = localContext.split("\n\n");
  entries.forEach(function(entry, i) {
    var titleMatch = entry.match(/Title: (.*)/); var detailMatch = entry.match(/Detail: (.*)/);
    if (titleMatch) parts.push('<p><strong>' + titleMatch[1] + '</strong></p>');
    if (detailMatch) parts.push('<p>' + detailMatch[1] + '</p>');
  });
  parts.push('<p><strong>What this means for you:</strong></p><ul><li>Bring a structured summary of symptoms and concerns to your next visit</li><li>Ask specific questions - prepared patients get better care</li><li>If current treatment is not helping, discuss alternatives with your clinician</li></ul>');
  parts.push('<div class="chat-disclaimer">This information is for education only and does not replace professional medical advice.</div>');
  return parts.join('');
}

async function sendChat() {
  if (S.chatBusy) return;
  var input = $("chatInput"); if (!input) return;
  var query = input.value.trim();
  if (!query) { toast("Type a question or topic first."); return; }
  S.chatBusy = true; var sendBtn = $("chatSendBtn"); if (sendBtn) sendBtn.disabled = true;
  addChatMessage("user", "<p>" + query.replace(/</g, "&lt;").replace(/>/g, "&gt;") + "</p>");
  input.value = ""; var sp = $("suggestedPrompts"); if (sp) sp.innerHTML = "";
  addTypingIndicator();

  try {
    var responseHtml = await getAIResponse(query);
    removeTypingIndicator();
    var bubble = addChatMessage("ai", "");
    if (bubble) { typeResponse(bubble, responseHtml, function() { S.chatBusy = false; if (sendBtn) sendBtn.disabled = false; }); }
    else { S.chatBusy = false; if (sendBtn) sendBtn.disabled = false; }
  } catch (e) {
    removeTypingIndicator();
    addChatMessage("ai", "<p>Sorry, I encountered an error processing your request. Please try again.</p>");
    S.chatBusy = false; if (sendBtn) sendBtn.disabled = false;
  }
}

function renderSuggestedPrompts() { var container = $("suggestedPrompts"); if (!container) return; container.innerHTML = ""; var shuffled = suggestedPrompts.slice().sort(function() { return 0.5 - Math.random(); }); shuffled.slice(0, 4).forEach(function(p) { var chip = mkEl("button", "prompt-chip", p); chip.type = "button"; chip.onclick = function() { $("chatInput").value = p; sendChat(); }; container.appendChild(chip); }); }

