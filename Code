    .map-pins { position: absolute; inset: 0; pointer-events: none; z-index: 10; }
    .map-pin { position: absolute; border: none; border-radius: 999px; display: grid; place-items: center; color: #fff; font-weight: 800; cursor: pointer; pointer-events: all; box-shadow: 0 14px 24px rgba(0,0,0,.22); z-index: 12; transform: translate(-50%, -50%) scale(var(--pin-cs, 1)); transition: all .25s cubic-bezier(.4,0,.2,1); }
