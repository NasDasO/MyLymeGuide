    .focus-tag { background: #FFF6E9; color: #9A6A1A; border-color: #F0D9A8; }
    .doc-footer { background: #F8FBF9; border-top: 1px solid var(--pdf-border); padding: 14px 28px; display: flex; align-items: flex-start; gap: 10px; }
