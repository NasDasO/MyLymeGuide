            row.innerHTML = `<span class="symptom-name-pdf">${sym.label}</span><div class="symptom-dots">${dotsHtml}<span class="sym-score">${score}/4</span></div>`;
            body.appendChild(row);
        }); col.appendChild(body); grid.appendChild(col);
    }

    const concernsContainer = document.getElementById('pdfConcernsContainer'); concernsContainer.innerHTML = '';
    const allConcerns = []; ['cognitive','sleep','mood','heart','digestive','patterns','func','treatment'].forEach(g => { if (S.chips[g] && S.chips[g].length) allConcerns.push(...S.chips[g]); });
    [S.complaint1, S.complaint2, S.complaint3].filter(c => c).forEach(c => allConcerns.push(c));
    urgentItems.forEach(item => { if (S.urgent[item.key] === 'yes') allConcerns.push("⚠️ " + item.label); });
    [...new Set(allConcerns)].forEach(c => { concernsContainer.innerHTML += `<span class="tag"><span>${c}</span></span>`; });

    const focusContainer = document.getElementById('pdfFocusContainer'); focusContainer.innerHTML = '';
    (S.chips.help.length ? S.chips.help : ["General follow-up"]).forEach(f => { focusContainer.innerHTML += `<span class="tag focus-tag"><span>${f}</span></span>`; });

    // 3. Move element on screen so canvas can paint it
    const wrapper = document.getElementById('pdfWrapper');
    wrapper.style.position = 'absolute';
    wrapper.style.left = '0px';
    wrapper.style.top = '0px';
    wrapper.style.zIndex = '-9999'; // Behind UI
    wrapper.style.opacity = '1';
    wrapper.style.display = 'block';
    wrapper.style.pointerEvents = 'none';

    // Wait for 2 frames to ensure browser paints
    await new Promise(resolve => requestAnimationFrame(() => requestAnimationFrame(resolve)));

    const element = document.getElementById('docPage');
    const opt = {
        margin: [8, 4, 8, 4],
        filename: 'MyLymeGuide_Questionnaire_Summary.pdf',
        image: { type: 'jpeg', quality: 0.98 },
        html2canvas: { scale: 2, useCORS: true, logging: false },
        jsPDF: { unit: 'mm', format: 'a4', orientation: 'portrait' }
    };

    // 4. Generate and Save
    await html2pdf().set(opt).from(element).save();
    toast("PDF downloaded successfully!");

  } catch(err) {
    console.error("PDF Generation Failed:", err);
    toast("PDF Error: " + (err.message || "Unknown issue"));
  } finally {
    // 5. Always hide wrapper again
    const wrapper = document.getElementById('pdfWrapper');
    wrapper.style.position = 'absolute'; 
    wrapper.style.left = '-10000px'; 
    wrapper.style.opacity = '0';
  }
}

