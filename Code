ng","latest":"emerging","recent":"emerging","update":"emerging","current":"emerging","herx":"herx","die-off":"herx","herxheimer":"herx","reinfection":"reinfection","relapse":"reinfection","climate":"climate-change","warming":"climate-change","overview":"general","summary":"general","explain":"general","what-is":"general"};
var KB = [
{id:"ptlds-def",yr:2024,tags:["ptlds","persistent","chronic","long-term","ongoing","post-treatment","lingering","prolonged"],title:"Post-Treatment Lyme Disease Syndrome (PTLDS)",text:"PTLDS is defined as persistent fatigue, musculoskeletal pain, and cognitive complaints lasting more than 6 months after completing recommended antibiotic treatment for Lyme disease. The CDC and IDSA recognize PTLDS as a real clinical entity. Estimated prevalence ranges from 10-20% of treated patients."},
{id:"ptlds-spectrum",yr:2023,tags:["ptlds","persistent","spectrum","severity","variable","symptoms"],title:"Spectrum of persistent symptoms",text:"Persistent symptoms exist on a spectrum. Most commonly reported: fatigue (70-85%), musculoskeletal pain (50-65%), cognitive difficulties (40-55%), sleep disturbance (45-60%), and neuropathic symptoms (30-40%). The pattern often fluctuates."},
{id:"ptlds-prevalence",yr:2022,tags:["ptlds","persistent","prevalence","how-many","percentage","statistics","common"],title:"Prevalence of persistent symptoms",text:"A 2022 meta-analysis estimated approximately 14.9% of confirmed Lyme patients reported persistent symptoms at 6 months. A Netherlands study found 26% with at least one severe symptom at 12 months."},
{id:"ptlds-quality",yr:2021,tags:["ptlds","persistent","quality-of-life","function","disability","impact","burden","working"],title:"Quality of life impact",text:"PTLDS patients score significantly lower than the general population on quality-of-life instruments, often comparable to congestive heart failure or multiple sclerosis. 37% reported being unable to work or significantly reducing work hours."},
{id:"test-twotier",yr:2019,tags:["testing","diagnosis","test","two-tier","elisa","western-blot","antibody","serology","blood-test","lab"],title:"Two-tier testing for Lyme disease",text:"Standard diagnosis: EIA/ELISA screening followed by Western blot confirmation. Revised in 2019 to allow two EIA tests. Sensitivity is notably poor in early infection (first 4-6 weeks)."},
{id:"test-false-neg",yr:2023,tags:["testing","false-negative","negative","early","week","seronegative","missed","antibody","window"],title:"False-negative testing in early Lyme",text:"During the first 2-4 weeks, antibody-based tests have sensitivity as low as 30-40%. Antibodies take 4-6 weeks to develop. A negative test during this window does not rule out Lyme. The CDC states treatment should not be delayed pending test results."},
{id:"test-accuracy",yr:2020,tags:["testing","accuracy","sensitivity","specificity","reliable","false-positive"],title:"Test accuracy and limitations",text:"For later manifestations, sensitivity improves to 80-95%. Tests cannot distinguish active from past infection since IgG antibodies persist for years."},
{id:"test-new",yr:2024,tags:["testing","new","novel","pcr","culture","metabolomics","biomarker","phage","better-test"],title:"New and emerging diagnostic approaches",text:"Research avenues: direct detection via PCR/culture; metabolomic signatures; phage-based detection; T-cell assays (EliSpot). None have replaced standard two-tier testing."},
{id:"test-neuro",yr:2022,tags:["testing","neuroborreliosis","csf","spinal-fluid","intrathecal","neurological","lumbar-puncture"],title:"Testing for neuroborreliosis",text:"Confirmed by demonstrating intrathecal antibody production. CSF-to-serum antibody index above 2 suggests CNS antibody production. Can be negative in early neuroborreliosis."},
{id:"tx-standard",yr:2020,tags:["treatment","antibiotic","doxycycline","amoxicillin","cefuroxime","standard","guideline","idsa","course","duration"],title:"Standard antibiotic treatment",text:"IDSA guidelines: early Lyme - doxycycline 100mg BID, amoxicillin 500mg TID, or cefuroxime 500mg BID for 14-21 days. Neuroborreliosis - IV ceftriaxone 2g daily for 14-28 days. Lyme arthritis - oral antibiotics for 28 days."},
{id:"tx-ilads",yr:2020,tags:["treatment","ilads","longer","extended","individualized","alternative","debate","controversy"],title:"ILADS treatment approach",text:"ILADS advocates individualized treatment duration, longer courses when symptoms persist, and retreatment in selected cases. Not endorsed by IDSA, CDC, or most infectious disease societies."},
{id:"tx-retreat",yr:2016,tags:["treatment","retreatment","re-treat","second-course","repeat"],title:"Retreatment studies",text:"Four major NIH RCTs: Klempner (2001) - no significant benefit; Krupp (2003) - improved fatigue only; Fallon (2008) - temporary cognitive improvement not sustained, with significant adverse events."},
{id:"tx-harm",yr:2017,tags:["treatment","antibiotic","risk","harm","side-effect","adverse","safety","long-term-antibiotics"],title:"Risks of prolonged antibiotics",text:"Prolonged IV therapy carries measurable risks: catheter infections, C. difficile, resistance, toxicity. 26% serious adverse events in one study. Risk-benefit ratio remains unfavorable per most evidence reviews."},
{id:"tx-symptom",yr:2023,tags:["treatment","symptomatic","management","rehabilitation","exercise","physical-therapy","sleep","pain-management"],title:"Symptom-focused management",text:"Evidence favors symptom-directed management: graded exercise (adapted), CBT for coping and sleep, pain management, physical therapy. A 2023 European consensus emphasized multimodal approaches."},
{id:"tx-persist-debate",yr:2024,tags:["treatment","persistence","bacterial","survival","biofilm","persister","viable"],title:"The bacterial persistence debate",text:"In vitro, Borrelia can form persisters and biofilm-like structures. However, no study has conclusively demonstrated viable, culturable Borrelia in humans after appropriate treatment."},
{id:"mech-immune",yr:2023,tags:["mechanism","immune","inflammation","autoimmune","dysregulation","cytokine","post-infectious"],title:"Immune dysregulation",text:"Growing evidence supports post-infectious immune dysregulation: elevated inflammatory cytokines; altered T-cell subsets; Aucott et al. (2023) identified distinct immune signatures in PTLDS versus recovered patients."},
{id:"mech-cellwall",yr:2024,tags:["mechanism","cell-wall","peptidoglycan","remnant","debris","inflammation","residual"],title:"Cell wall remnants driving inflammation",text:"A landmark 2024 study showed Borrelia peptidoglycan persists in joints of treated patients and continues driving inflammatory responses. This remnant is not eliminated by antibiotics because it is structural."},
{id:"mech-neuroinfl",yr:2022,tags:["mechanism","neuroinflammation","brain","cns","glial","cognitive","brain-fog"],title:"Neuroinflammatory mechanisms",text:"PET imaging with TSPO ligands shows widespread glial activation in PTLDS patients, correlating with cognitive symptom severity. Similar patterns appear in other post-infectious syndromes."},
{id:"mech-autonomic",yr:2021,tags:["mechanism","autonomic","dysautonomia","pots","orthostatic","standing","heart-rate","fainting"],title:"Autonomic dysfunction",text:"25-45% of PTLDS patients show objective autonomic dysfunction on tilt-table testing, particularly POTS. Overlaps with ME/CFS and long COVID."},
{id:"mech-overlap",yr:2023,tags:["mechanism","overlap","me-cfs","long-covid","fibromyalgia","post-infectious","similar"],title:"Overlap with ME/CFS, long COVID, fibromyalgia",text:"Significant overlap: profound fatigue, post-exertional malaise, cognitive dysfunction, sleep disturbance, autonomic dysfunction. These may represent a spectrum of post-infectious chronic illness."},
{id:"rash-em",yr:2022,tags:["rash","bullseye","erythema-migrans","skin","tick-bite","expanding","red"],title:"Erythema migrans (the Lyme rash)",text:"Occurs in 70-80% of cases. Classic bullseye less common than uniformly red expanding patch. Appears 3-30 days after bite. Absence does not exclude Lyme. Treatment should begin immediately."},
{id:"neuro-clinical",yr:2021,tags:["neuroborreliosis","neurological","cns","cranial-nerve","facial","palsy","meningitis","radiculopathy"],title:"Clinical features of neuroborreliosis",text:"Affects 10-15% of untreated patients. Presentations: lymphocytic meningitis, cranial neuritis (facial palsy), radiculoneuritis (Bannwarth syndrome), rarely encephalomyelitis."},
{id:"neuro-cognitive",yr:2023,tags:["neurological","cognitive","brain-fog","memory","concentration","attention","thinking"],title:"Cognitive symptoms",text:"Affected domains: processing speed, working memory, verbal fluency, attention. Formal testing shows real deficits. A 2023 study found cognitive symptoms correlate with neuroinflammatory markers."},
{id:"cardiac",yr:2020,tags:["cardiac","heart","carditis","av-block","palpitation","chest","arrhythmia"],title:"Lyme carditis",text:"Occurs in 1-5% of untreated cases. Hallmark is AV block which can fluctuate rapidly. CDC documented fatal cases. Most resolves with antibiotics. Any unexplained high-degree AV block in endemic areas warrants testing."},
{id:"coinfection",yr:2022,tags:["co-infection","coinfection","babesia","anaplasma","ehrlichia","bartonella","other-tick-borne"],title:"Tick-borne co-infections",text:"Ixodes ticks transmit multiple pathogens. Recognized co-infections: Babesia microti (babesiosis), Anaplasma (anaplasmosis). Prevalence may be 10-30% of Lyme cases. Suspect when severity is greater or response to treatment is inadequate."},
{id:"vaccine-vla15",yr:2025,tags:["vaccine","vla15","pfizer","valneva","prevention","efficacy","trial"],title:"VLA15 Lyme vaccine",text:"Multivalent OspA subunit vaccine targeting six Borrelia serotypes. Phase 3: approximately 73.2% efficacy after the fourth dose, no significant safety concerns. Would be the first Lyme vaccine since LYMErix withdrawal in 2002."},
{id:"vaccine-lymerix",yr:2019,tags:["vaccine","lymerix","history","withdrawn","safety-controversy"],title:"LYMErix lessons",text:"Approved 1998, ~76% efficacy. Withdrawn 2002 due to low sales and alleged autoimmune concerns. Subsequent analyses found no convincing evidence of autoimmune disease. Informed VLA15 design."},
{id:"epi-us",yr:2024,tags:["epidemiology","united-states","us","cases","incidence","cdc","surveillance"],title:"US epidemiology",text:"CDC estimates ~476,000 Americans diagnosed/treated annually. Concentrated in Northeast, mid-Atlantic, and upper Midwest. Range expanding due to climate change."},
{id:"epi-europe",yr:2023,tags:["epidemiology","europe","eu","ecdc","cases","incidence","netherlands","germany"],title:"European epidemiology",text:"ECDC estimates 200,000+ cases annually in EU/EEA. Highest in Central and Northern Europe. Different Borrelia species affect clinical presentation."},
{id:"epi-climate",yr:2023,tags:["epidemiology","climate-change","warming","expansion","range","spread"],title:"Climate change and tick expansion",text:"Warming temperatures expanding Ixodes range northward. Canadian provinces now endemic. European seasons lengthening. Continued expansion projected."},
{id:"controversy-chronic",yr:2024,tags:["controversy","chronic-lyme","terminology","debate","idsa","ilads"],title:"The chronic Lyme terminology debate",text:"Preferred terms: PTLDS or Lyme with persistent symptoms. Both the reality of persistent symptoms AND lack of evidence for prolonged antibiotics are supported by current evidence."},
{id:"controversy-antibiotics",yr:2023,tags:["controversy","antibiotics","long-term","prolonged","debate","treatment"],title:"The prolonged antibiotics debate",text:"RCTs show limited/no sustained benefit with measurable risks. 2023 European guideline recommends against prolonged antibiotics for PTLDS."},
{id:"sym-fatigue",yr:2023,tags:["fatigue","tired","exhausted","energy","post-exertional","pem","crash","weariness"],title:"Fatigue in PTLDS",text:"Affects 70-85% of PTLDS patients. Often profound. Many experience post-exertional malaise (PEM). Management: pacing, sleep optimization, gradual activity tailored to tolerance."},
{id:"sym-pain",yr:2022,tags:["pain","joint","muscle","arthritis","myalgia","migrating","musculoskeletal","stiffness","swelling"],title:"Pain in PTLDS",text:"Lyme arthritis typically affects large joints (knee). In PTLDS, pain is often diffuse. The 2024 peptidoglycan finding provides a mechanism for persistent joint inflammation."},
{id:"sym-sleep",yr:2021,tags:["sleep","insomnia","unrefreshing","waking","disturbance"],title:"Sleep disturbance",text:"Affects 45-60% of PTLDS patients: difficulty falling asleep, frequent waking, unrefreshing sleep. Creates a vicious cycle worsening other symptoms."},
{id:"sym-mood",yr:2022,tags:["mood","anxiety","depression","irritability","psychological","mental-health"],title:"Mood and psychological symptoms",text:"Anxiety, depression, irritability in 30-50% of PTLDS patients. May be primary neuroinflammatory effects, secondary to chronic illness, or both."},
{id:"special-pediatric",yr:2022,tags:["pediatric","child","children","kid","young"],title:"Lyme in children",text:"Children more commonly present with EM and facial palsy. Doxycycline avoided under age 8; amoxicillin preferred."},
{id:"special-pregnancy",yr:2021,tags:["pregnancy","pregnant","breastfeeding","congenital","maternal"],title:"Lyme during pregnancy",text:"Untreated Lyme may be associated with adverse outcomes. Should be treated promptly. Doxycycline generally avoided; amoxicillin preferred. Breastfeeding considered safe during/after treatment."},
{id:"rehab-graded",yr:2023,tags:["rehabilitation","exercise","graded","activity","physical-therapy","pacing"],title:"Graded activity and rehabilitation",text:"Evidence supports: pacing within energy limits; avoiding PEM triggers; very gradual progression; recumbent exercise for POTS patients; multidisciplinary support."},
{id:"rehab-cognitive",yr:2022,tags:["rehabilitation","cognitive","strategy","memory","attention"],title:"Cognitive rehabilitation",text:"External memory aids; environmental modifications; cognitive pacing; formal cognitive rehabilitation. A 2022 pilot showed modest improvements."},
{id:"rehab-nutrition",yr:2020,tags:["nutrition","diet","supplements","vitamin","omega-3","vitamin-d"],title:"Nutritional considerations",text:"Anti-inflammatory dietary patterns may help. Vitamin D (deficiency common), omega-3s, probiotics, magnesium. Evidence for PTLDS specifically is limited."},
{id:"emerging-biomarkers",yr:2024,tags:["biomarker","new","emerging","research","future","diagnostic"],title:"Emerging PTLDS biomarkers",text:"Immune signatures; metabolomic profiles; TSPO-PET neuroimaging. A 2024 study identified a 6-marker panel with 82% accuracy."},
{id:"emerging-treatment",yr:2025,tags:["treatment","new","emerging","future","novel","therapy"],title:"Emerging treatments",text:"Hygromycin A (narrow-spectrum Borrelia antibiotic); Disulfiram (mixed results); immunomodulatory approaches; neuromodulation. Most remain experimental."},
{id:"visit-prep",yr:2024,tags:["doctor","visit","appointment","prepare","questions","ask","clinician"],title:"Preparing for a doctor visit",text:"Bring symptom timeline; list symptoms with severity; document what has/has not helped; bring test results; prepare 3-5 key questions; consider a support person."},
{id:"visit-questions",yr:2024,tags:["doctor","visit","questions","ask","focus","key-topics"],title:"Key questions for your doctor",text:"Could symptoms be from something else? Should we repeat testing? Are there red flags? What symptom management exists? How evaluate if treatment works?"},
{id:"visit-redflags",yr:2023,tags:["red-flag","urgent","emergency","warning-sign","danger","severe","immediate"],title:"Red flag symptoms",text:"Seek immediate attention for: chest pain/palpitations; severe headache with fever/stiff neck; facial drooping; sudden vision changes; fainting; confusion/seizure; fever above 39C for 48+ hours; suicidal thoughts."},
{id:"covid-parallels",yr:2024,tags:["long-covid","covid","parallel","overlap","similar","post-viral","post-infectious"],title:"PTLDS and long COVID parallels",text:"Striking similarities reinvigorated PTLDS research. A 2024 NIH workshop recognized PTLDS as a model for understanding post-infectious chronic illness."},
{id:"prevention-tick",yr:2023,tags:["prevention","tick","bite","avoid","repellent","deet","permethrin","check","removal"],title:"Tick bite prevention",text:"EPA-registered repellents (DEET 20-30%, picaridin); permethrin-treated clothing; full-body tick checks; shower within 2 hours. Removal: fine-tipped tweezers, pull straight up."},
{id:"prevention-prophylaxis",yr:2022,tags:["prevention","prophylaxis","antibiotic","after-tick-bite","single-dose","doxycycline"],title:"Post-tick-bite prophylaxis",text:"IDSA recommends single 200mg doxycycline within 72 hours of removing an Ixodes tick attached 36+ hours in endemic area. Reduces Lyme risk approximately 87%."},
{id:"misc-herx",yr:2020,tags:["herx","jarisch-herxheimer","reaction","worse-before-better","die-off","flare"],title:"Jarisch-Herxheimer reaction",text:"Occurs in approximately 10-15% starting Lyme treatment. Flu-like worsening within hours caused by bacterial die-off. Typically lasts 12-72 hours."},
{id:"misc-reinfection",yr:2021,tags:["reinfection","new-infection","repeat","relapse","recurrence"],title:"Reinfection versus relapse",text:"Patients can be reinfected after treatment. Molecular fingerprinting confirms recurrent EM is typically reinfection with a different strain."},
{id:"misc-arthritis",yr:2023,tags:["arthritis","joint","swelling","knee","chronic","inflammatory"],title:"Lyme arthritis",text:"Typical: episodic knee swelling. 10-20% develop antibiotic-refractory arthritis - now understood as autoimmune/inflammatory, not ongoing infection. Treatment: NSAIDs, corticosteroids, sometimes DMARDs."},
{id:"misc-testing-timing",yr:2024,tags:["testing","when","timing","how-soon","repeat","retest"],title:"When to test and retest",text:"Do not test too early (poor sensitivity first 4-6 weeks). Retest at 4-6 weeks if initial negative but suspicion remains. Repeat testing after treatment generally NOT recommended."}
